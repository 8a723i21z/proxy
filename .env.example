# Address of the Minecraft backend the proxy wakes and forwards to (required).
BACKEND_ADDR=your-backend-host:25565

# Port the proxy listens on (optional, defaults to 25565).
PORT=25565

# MOTD shown while the backend is asleep. No quotes needed; spaces preserved.
# Accepts any of:
#   - & color/format codes: &c red, &l bold, &r reset
#   - &#RRGGBB or Bungee &x&R&R&G&G&B&B hex codes (for gradients)
#   - a raw JSON chat component starting with { or [ (used verbatim; best for
#     gradients since it renders exactly as written)
# Gradient example (JSON): {"text":"","extra":[{"text":"C","color":"#54DAF4"}, ...]}
MOTD=&c&lServer is asleep &r&7— join to wake it up!

# Optional: custom MOTD shown while the backend is online. The real player
# count and version are always taken live from the backend; this only overrides
# the description text (supports & color codes). Leave unset to also show the
# backend's own description.
MOTD_ONLINE=&aServer is UP — come play!

# How long (seconds) the container stays awake after the last player leaves,
# i.e. its idle-sleep timer. The proxy treats the backend as online for this
# long after the last player disconnects, and only probes it during that window
# (so it never wakes a sleeping container). Set this at or slightly BELOW your
# container's real sleep timer — e.g. 540 for a 10-minute timer leaves a safety
# margin so the proxy stops probing before the container actually sleeps.
# Optional, defaults to 600.
SLEEP_TIMEOUT_SECS=540

# How long (seconds) the background wake keeps retrying the backend connection
# before giving up. Optional, defaults to 120.
CONNECT_TIMEOUT_SECS=120

# How long (seconds) after the last player leaves the proxy keeps fetching the
# backend's real status (description/max/favicon) for the online MOTD. Probing
# stops after this, so the container can sleep. MUST be well below the
# container's idle-sleep timer (probing counts as traffic and would keep it
# awake). The live player count always comes from the proxy itself, so it stays
# accurate even between/after probes. Optional, defaults to 60.
PROBE_GRACE_SECS=60

# Message shown to a player who joins while the backend is still booting. The
# proxy triggers the boot in the background and disconnects them with this text
# so they don't hit the client's ~30s login timeout — they just rejoin once it's
# up. Supports the same & color/hex codes and JSON as MOTD; use \n for newlines.
STARTUP_MESSAGE=&e&lServer is starting up!\n&7Please rejoin in a few seconds.
