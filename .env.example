# Address of the Minecraft backend the proxy wakes and forwards to (required).
BACKEND_ADDR=your-backend-host:25565

# Port the proxy listens on (optional, defaults to 25565).
PORT=25565

# MOTD shown while the backend is asleep. No quotes needed; spaces preserved.
# Accepts any of:
#   - & color/format codes: &c red, &l bold, &r reset
#   - &#RRGGBB or Bungee &x&R&R&G&G&B&B hex codes
#   - a <gradient:#RRGGBB:#RRGGBB[:#RRGGBB...]>text</gradient> tag — colors each
#     character along the stops; text inside is literal (no & codes)
#   - a raw JSON chat component starting with { or [ (used verbatim)
# Gradient example: <gradient:#54DAF4:#6DB654>Claudecraft</gradient> is asleep!
MOTD=&c&lServer is asleep &r&7— join to wake it up!

# Optional: custom MOTD shown while the backend is online. The player count is
# always the proxy's own live connection count (accurate, no backend probing).
# This overrides the description text (supports & color/hex codes). Leave unset
# to show the backend's own description instead (fetched while players online).
MOTD_ONLINE=&aServer is UP — come play!

# Fallback max-players shown on the online MOTD before the proxy has cached the
# backend's real max. The cache is seeded automatically when a player joins, so
# this only shows briefly; set it to your server's real max so the two always
# agree. Optional, defaults to 20.
MAX_PLAYERS=20

# Optional server icon for statuses the proxy builds itself (offline MOTD and
# the pre-cache online MOTD). Must be a 64x64 PNG as a data URI, all one line:
#   FAVICON=data:image/png;base64,iVBORw0KGgo...
# While the backend's status is cached, its own favicon passes through instead.
# FAVICON=

# How long (seconds) after the last player leaves the proxy keeps showing the
# ONLINE MOTD (from cache/MOTD_ONLINE, with 0 players) before switching to the
# offline MOTD. Purely cosmetic: the proxy never contacts the backend while idle,
# so this does NOT affect when the container sleeps. Set it to roughly match your
# container's idle-sleep timer so the MOTD flips to offline around when it sleeps.
# Optional, defaults to 600.
SLEEP_TIMEOUT_SECS=600

# How long (seconds) the background wake keeps retrying the backend connection
# before giving up. Optional, defaults to 120.
CONNECT_TIMEOUT_SECS=120

# How long (seconds) a player who joins during a cold start is held on the
# connecting screen while the backend boots. The proxy keeps their login alive
# and puts them through the moment the server is ready, so they never have to
# rejoin. Set this comfortably above your server's boot time. If it runs out
# (or the client is older than 1.13) they get STARTUP_MESSAGE instead.
# Set to 0 to always disconnect immediately. Optional, defaults to 90.
JOIN_HOLD_SECS=90

# Cap on simultaneously open client connections (players, pings, scanners).
# Excess connections are dropped immediately so a flood can't exhaust file
# descriptors or memory. Optional, defaults to 256.
MAX_CONNECTIONS=256

# Fallback message for a cold join the hold couldn't cover: the backend didn't
# come up within JOIN_HOLD_SECS, the hold is disabled, or the client is older
# than 1.13. The boot still runs in the background, so rejoining shortly after
# works. Supports the same & color/hex codes and JSON as MOTD; \n for newlines.
STARTUP_MESSAGE=&e&lServer is starting up!\n&7Please rejoin in a few seconds.
