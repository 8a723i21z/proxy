# Address of the Minecraft backend the proxy wakes and forwards to (required).
BACKEND_ADDR=your-backend-host:25565

# Port the proxy listens on (optional, defaults to 25565).
PORT=25565

# MOTD shown while the backend is asleep.
# No quotes needed; spaces are preserved.
# Supports Bukkit-style & color/format codes: &c red, &l bold, &r reset, etc.
MOTD=&c&lServer is asleep &r&7— join to wake it up!

# Optional: static MOTD shown while the backend is online.
# Leave unset to relay the backend's real MOTD (live description/player count).
MOTD_ONLINE=Server is UP — come play!

# How long (seconds) the container stays awake after the last player leaves,
# i.e. its idle-sleep timer. The proxy treats the backend as online for this
# long after the last player disconnects, and only probes it during that window
# (so it never wakes a sleeping container). Set this at or slightly BELOW your
# container's real sleep timer — e.g. 540 for a 10-minute timer leaves a safety
# margin so the proxy stops probing before the container actually sleeps.
# Optional, defaults to 600.
SLEEP_TIMEOUT_SECS=540
